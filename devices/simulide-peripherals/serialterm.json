{
  "schemaVersion": 1,
  "typeId": "peripherals.serialterm",
  "name": "Terminal Serial",
  "language": "pt-BR",
  "icon": "serialterm",
  "folderPath": ["Periféricos"],
  "translations": {
    "en": {
      "name": "Serial Terminal",
      "properties": {
        "baudrate":  { "label": "Baud rate",         "group": "Serial" },
        "data_bits": { "label": "Data bits",         "group": "Serial" },
        "stop_bits": { "label": "Stop bits",         "group": "Serial" },
        "rx_buffer": { "label": "RX buffer (send)",  "group": "Serial" },
        "tx_bytes":  { "label": "TX received (hex)", "group": "Serial" }
      }
    }
  },
  "abiVersion": { "major": 4, "minor": 0 },
  "nativeEntry": {
    "win32-x64":        "build-msvc/device.dll",
    "linux-x64":        "build/linux-x64/device.so",
    "darwin-universal": "build/macos-universal/device.dylib"
  },
  "package": {
    "width": 80,
    "height": 40,
    "border": false,
    "background": { "kind": "color", "value": "transparent" },
    "shapes": [
      { "kind": "rect", "x": 0,  "y": 0,  "w": 80, "h": 40, "stroke": "#333", "fill": "#1a1a1a", "strokeWidth": 2 },
      { "kind": "text", "x": 14, "y": 16, "value": "SERIAL",  "fontSize": 9, "color": "#00ff44" },
      { "kind": "text", "x": 20, "y": 30, "value": "TERMINAL","fontSize": 7, "color": "#00cc33" },
      { "kind": "rect", "x": 66, "y": 6,  "w": 8,  "h": 6,   "stroke": "#555", "fill": "#220" },
      { "kind": "rect", "x": 66, "y": 16, "w": 8,  "h": 6,   "stroke": "#555", "fill": "#022" },
      { "kind": "text", "x": 66, "y": 12, "value": "TX", "fontSize": 5, "color": "#fa0" },
      { "kind": "text", "x": 66, "y": 22, "value": "RX", "fontSize": 5, "color": "#0af" }
    ],
    "pinLabelColor": "#FAFAC8",
    "pins": [
      { "id": "tx", "x": 0, "y": 12, "angle": 180, "length": 8, "label": "TX" },
      { "id": "rx", "x": 0, "y": 26, "angle": 180, "length": 8, "label": "RX" }
    ]
  },
  "pins": [
    { "id": "tx", "kind": "DIGITAL_OUT", "x": 0, "y": 12, "angle": 180, "length": 8, "label": "TX" },
    { "id": "rx", "kind": "DIGITAL_IN",  "x": 0, "y": 26, "angle": 180, "length": 8, "label": "RX" }
  ],
  "properties": [
    { "id": "baudrate",  "label": "Baud rate",           "group": "Serial", "valueKind": "number", "editor": "select", "default": 9600,
      "options": [
        {"label":"1200",   "value":1200},
        {"label":"2400",   "value":2400},
        {"label":"4800",   "value":4800},
        {"label":"9600",   "value":9600},
        {"label":"19200",  "value":19200},
        {"label":"38400",  "value":38400},
        {"label":"57600",  "value":57600},
        {"label":"115200", "value":115200}
      ]
    },
    { "id": "data_bits", "label": "Bits de dados",       "group": "Serial", "valueKind": "number", "editor": "select", "default": 8,
      "options": [{"label":"5","value":5},{"label":"6","value":6},{"label":"7","value":7},{"label":"8","value":8}]
    },
    { "id": "stop_bits", "label": "Bits de parada",      "group": "Serial", "valueKind": "number", "editor": "select", "default": 1,
      "options": [{"label":"1","value":1},{"label":"2","value":2}]
    },
    { "id": "rx_buffer", "label": "Buffer RX (enviar)", "group": "Serial", "valueKind": "string", "editor": "text", "default": "" },
    { "id": "tx_bytes",  "label": "TX recebido (hex)",  "group": "Serial", "valueKind": "string", "editor": "text", "default": "" }
  ],
  "limits": { "stepTimeoutMs": 1, "expectedComplexity": "medium" }
}
