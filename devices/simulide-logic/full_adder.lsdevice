    },
    "pins": [
      {
        "id": "a",
        "x": 8,
        "y": 8,
        "angle": 180,
        "length": 8,
        "label": "A"
      },
      {
        "id": "b",
        "x": 8,
        "y": 24,
        "angle": 180,
        "length": 8,
        "label": "B"
      },
      {
        "id": "cin",
        "x": 32,
        "y": 8,
        "angle": 0,
        "length": 8,
        "label": "CI"
      },
      {
        "id": "sum",
        "x": 32,
        "y": 16,
        "angle": 0,
        "length": 8,
        "label": "S"
      },
      {
        "id": "cout",
        "x": 32,
