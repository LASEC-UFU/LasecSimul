      "kind": "DIGITAL_IN"
    },
    {
      "id": "sum",
      "kind": "DIGITAL_OUT"
    },
    {
      "id": "cout",
      "kind": "DIGITAL_OUT"
    }
  ],
  "properties": [],
  "limits": {
    "stepTimeoutMs": 4,
    "expectedComplexity": "low"
  },
  "package": {
    "width": 40,
    "height": 32,
    "border": false,
    "background": { "kind": "none" },
    "viewSpec": {
