{
  "schemaVersion": 1,
  "typeId": "logic.full_adder",
  "name": "Full Adder",
  "language": "pt-BR",
  "icon": "2to2",
  "folderPath": ["Logicos", "Aritmeticos"],
  "abiVersion": {
    "major": 3,
    "minor": 0
  },
  "nativeEntry": {
    "win32-x64": "build-msvc/device.dll",
    "linux-x64": "build/linux-x64/device.so",
    "darwin-universal": "build/macos-universal/device.dylib"
  },
  "pins": [
