{
  "schemaVersion": 1,
  "typeId": "sensors.dht22",
  "name": "DHT22/11 — Sensor de Temperatura e Umidade",
  "language": "pt-BR",
  "translations": {
    "en": {
      "name": "DHT22/11 — Temperature & Humidity Sensor",
      "properties": {
        "model": { "label": "Model (11 or 22)", "group": "Sensor" },
        "temp":  { "label": "Temperature (°C)", "group": "Sensor" },
        "humi":  { "label": "Humidity (%RH)",   "group": "Sensor" }
      }
    }
  },
  "abiVersion": { "major": 4, "minor": 0 },
  "nativeEntry": {
    "win32-x64":        "build/win-x64/device.dll",
    "linux-x64":        "build/linux-x64/device.so",
    "darwin-universal": "build/macos-universal/device.dylib"
  },
  "package": {
    "width": 32,
    "height": 64,
    "border": true,
    "background": { "kind": "color", "value": "#e8f4ff" },
    "shapes": [
      { "kind": "text", "x": 4,  "y": 20, "value": "DHT", "fontSize": 9,  "color": "#224" },
      { "kind": "text", "x": 4,  "y": 34, "value": "22",  "fontSize": 11, "color": "#114" },
      { "kind": "text", "x": 4,  "y": 50, "value": "T°H%", "fontSize": 7, "color": "#446" }
    ],
    "pins": [
      { "id": "vcc",  "x": 4,  "y": 64, "angle": 90, "length": 8, "label": "VCC"  },
      { "id": "data", "x": 14, "y": 64, "angle": 90, "length": 8, "label": "DATA" },
      { "id": "nc",   "x": 22, "y": 64, "angle": 90, "length": 8, "label": "NC"   },
      { "id": "gnd",  "x": 30, "y": 64, "angle": 90, "length": 8, "label": "GND"  }
    ]
  },
  "pins": [
    { "id": "vcc",  "kind": "POWER",          "x": 4,  "y": 64, "angle": 90, "length": 8, "label": "VCC"  },
    { "id": "data", "kind": "DIGITAL_BIDIR",  "x": 14, "y": 64, "angle": 90, "length": 8, "label": "DATA" },
    { "id": "nc",   "kind": "POWER",          "x": 22, "y": 64, "angle": 90, "length": 8, "label": "NC"   },
    { "id": "gnd",  "kind": "POWER",          "x": 30, "y": 64, "angle": 90, "length": 8, "label": "GND"  }
  ],
  "properties": [
    { "id": "model", "label": "Modelo",          "group": "Sensor", "valueKind": "number", "editor": "select", "default": 22, "options": [{"label":"DHT11","value":11},{"label":"DHT22","value":22}] },
    { "id": "temp",  "label": "Temperatura (°C)","group": "Sensor", "valueKind": "number", "editor": "number", "default": 25.0, "min": -40,  "max": 80,  "step": 0.1, "unit": "°C" },
    { "id": "humi",  "label": "Umidade (%RH)",   "group": "Sensor", "valueKind": "number", "editor": "number", "default": 50.0, "min": 0,    "max": 100, "step": 0.1, "unit": "%"  }
  ],
  "limits": { "stepTimeoutMs": 2, "expectedComplexity": "medium" }
}
