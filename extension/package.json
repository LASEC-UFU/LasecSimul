{
  "name": "lasecsimul",
  "displayName": "LasecSimul",
  "description": "Simulador de circuitos eletrônicos com MCUs emulados via QEMU, inspirado no SimulIDE.",
  "license": "SEE LICENSE IN LICENSE.txt",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lasecsimul.openSchematicEditor",
        "title": "LasecSimul: Open Schematic Editor",
        "icon": "$(go-to-file)",
        "enablement": "!lasecsimul.schematicOpen"
      },
      {
        "command": "lasecsimul.run",
        "title": "LasecSimul: Run Simulation"
      },
      {
        "command": "lasecsimul.pause",
        "title": "LasecSimul: Pause Simulation"
      },
      {
        "command": "lasecsimul.stop",
        "title": "LasecSimul: Stop Simulation"
      },
      {
        "command": "lasecsimul.debugFirmware",
        "title": "LasecSimul: Debug Firmware",
        "icon": "$(debug-alt)"
      },
      {
        "command": "lasecsimul.palette.addComponent",
        "title": "LasecSimul: Add Palette Component"
      },
      {
        "command": "lasecsimul.palette.registerFile",
        "title": "LasecSimul: Registrar Dispositivo ABI/QEMU/Subcircuito",
        "icon": "$(add)"
      },
      {
        "command": "lasecsimul.newSubcircuit",
        "title": "LasecSimul: New Subcircuit",
        "icon": "$(symbol-module)",
        "enablement": "false"
      },
      {
        "command": "lasecsimul.openSettings",
        "title": "LasecSimul: Settings",
        "icon": "$(settings-gear)",
        "enablement": "false"
      },
      {
        "command": "lasecsimul.palette.removeRegistered",
        "title": "LasecSimul: Remover Dispositivo Registrado"
      },
      {
        "command": "lasecsimul.saveProject",
        "title": "LasecSimul: Save Project As..."
      },
      {
        "command": "lasecsimul.openProject",
        "title": "LasecSimul: Open Project..."
      },
      {
        "command": "lasecsimul.openRecentProject",
        "title": "LasecSimul: Open Recent Project..."
      },
      {
        "command": "lasecsimul.importProject",
        "title": "LasecSimul: Import Circuit..."
      },
      {
        "command": "lasecsimul.rotateSelectionCw",
        "title": "LasecSimul: Rotate Selection CW"
      },
      {
        "command": "lasecsimul.rotateSelectionCcw",
        "title": "LasecSimul: Rotate Selection CCW"
      },
      {
        "command": "lasecsimul.flipSelectionHorizontal",
        "title": "LasecSimul: Flip Selection Horizontal"
      },
      {
        "command": "lasecsimul.flipSelectionVertical",
        "title": "LasecSimul: Flip Selection Vertical"
      },
      {
        "command": "lasecsimul.undo",
        "title": "LasecSimul: Undo"
      },
      {
        "command": "lasecsimul.redo",
        "title": "LasecSimul: Redo"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lasecsimul",
          "title": "LasecSimul",
          "icon": "media/activity-icon.svg"
        }
      ]
    },
    "views": {
      "lasecsimul": [
        {
          "id": "lasecsimul.componentPalette",
          "name": "Components",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "LasecSimul",
      "properties": {
        "lasecsimul.language": {
          "type": "string",
          "enum": [
            "system",
            "pt-BR",
            "en"
          ],
          "default": "system",
          "description": "Language used by the LasecSimul editor, palette and property sheets."
        },
        "lasecsimul.simulation.targetStepUs": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "maximum": 1000000,
          "markdownDescription": "Duração mínima (µs) de cada ciclo de liquidação da simulação em tempo real. `0` = ilimitado (máxima velocidade). Aumente para câmera lenta ou para reduzir uso de CPU."
        },
        "lasecsimul.simulation.maxNonLinearIterations": {
          "type": "integer",
          "default": 0,
          "minimum": 0,
          "maximum": 1000,
          "markdownDescription": "Limite de iterações não-lineares por passo de liquidação. `0` = ilimitado. Reduzir pode evitar loops em circuitos oscilatórios, com alguma perda de precisão."
        },
        "lasecsimul.simulation.integrationMethod": {
          "type": "string",
          "enum": [
            "automatic",
            "backwardEuler",
            "trapezoidal",
            "gear2"
          ],
          "default": "automatic",
          "description": "Método de integração transiente."
        },
        "lasecsimul.simulation.adaptiveTimeStep": {
          "type": "boolean",
          "default": true,
          "description": "Adapta e rejeita passos conforme o erro dos estados reativos."
        },
        "lasecsimul.simulation.initialStepNs": {
          "type": "number",
          "default": 100,
          "minimum": 1
        },
        "lasecsimul.simulation.minimumStepNs": {
          "type": "number",
          "default": 1,
          "minimum": 1
        },
        "lasecsimul.simulation.maximumStepNs": {
          "type": "number",
          "default": 100000,
          "minimum": 1
        },
        "lasecsimul.simulation.relativeTolerance": {
          "type": "number",
          "default": 0.0001,
          "exclusiveMinimum": 0
        },
        "lasecsimul.simulation.absoluteTolerance": {
          "type": "number",
          "default": 1e-9,
          "exclusiveMinimum": 0
        },
        "lasecsimul.simulation.telemetryRateHz": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 60,
          "description": "Taxa de atualização visual. Leituras são enviadas em lote e não alteram a frequência do solver."
        },
        "lasecsimul.debug.gdbPath": {
          "type": "string",
          "default": "xtensa-esp32-elf-gdb",
          "description": "Caminho do GDB compatível com a CPU emulada pelo QEMU."
        },
        "lasecsimul.ui.showComponentIds": {
          "type": "boolean",
          "default": false,
          "description": "Exibe o identificador (ex: 'Resistor-1') junto de cada componente no esquemático por padrão."
        },
        "lasecsimul.ui.snapToGrid": {
          "type": "boolean",
          "default": true,
          "description": "Encaixa componentes na grade ao posicionar e mover."
        }
      }
    },
    "menus": {
      "view/title": [
        {
          "command": "lasecsimul.openSchematicEditor",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@1"
        },
        {
          "command": "lasecsimul.palette.registerFile",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@2"
        },
        {
          "command": "lasecsimul.newSubcircuit",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@50"
        },
        {
          "command": "lasecsimul.openSettings",
          "when": "view == lasecsimul.componentPalette",
          "group": "navigation@999"
        }
      ]
    },
    "keybindings": [
      {
        "command": "lasecsimul.rotateSelectionCw",
        "key": "ctrl+r",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.rotateSelectionCcw",
        "key": "ctrl+shift+r",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.flipSelectionHorizontal",
        "key": "h",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.flipSelectionVertical",
        "key": "v",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.undo",
        "key": "ctrl+z",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.redo",
        "key": "ctrl+y",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      },
      {
        "command": "lasecsimul.redo",
        "key": "ctrl+shift+z",
        "when": "activeWebviewPanelId == 'lasecsimul.schematic'"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./ && tsc -p ./tsconfig.webview.json",
    "watch": "tsc -p ./ -w",
    "watch:webview": "tsc -p ./tsconfig.webview.json -w",
    "pretest": "npm run compile && tsc -p ./tsconfig.test.json",
    "test": "node out-test/test/project/ProjectSerializer.test.js && node out-test/src/ipc/CoreClient.test.js && node out-test/src/catalog/UnifiedCatalog.test.js && node out-test/src/catalog/registeredSources.test.js && node out-test/src/catalog/catalogMerge.test.js && node out-test/src/catalog/simulideGraphicalCatalog.test.js && node out-test/src/language.test.js && node out-test/src/ui/webview/paletteTree.test.js && node out-test/src/ui/webview/wireGeometry.test.js && node out-test/src/ui/webview/componentGeometry.test.js && node out-test/src/ui/webview/wireTopology.test.js && node out-test/src/ui/webview/topologyDocument.test.js && node out-test/src/ui/webview/subcircuitBoardMode.test.js && node out-test/src/ui/webview/valueFormatting.test.js && node out-test/src/ui/webview/componentSymbols.test.js && node out-test/src/ui/webview/batchProperties.test.js && node out-test/src/ui/webview/instrumentTrigger.test.js && node out-test/src/ui/webview/instrumentViewport.test.js && node out-test/src/catalog/simulideSceneTranslator.test.js && node out-test/src/trust/trustDecision.test.js && node out-test/src/catalog/subcircuitPackageAuthoring.test.js",
    "test:e2e": "npm run compile && node test/e2e/run-webview-e2e.cjs",
    "test:e2e:update": "npm run compile && set UPDATE_SNAPSHOTS=1&& node test/e2e/run-webview-e2e.cjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "@types/node": "^20.0.0",
    "@types/pngjs": "^6.0.5",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.4.0"
  }
}
