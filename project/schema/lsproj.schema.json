{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lasecsimul.dev/schema/lsproj.schema.json",
  "title": "LasecSimul Project",
  "type": "object",
  "required": ["schemaVersion", "components", "topology", "visual", "simulationSettings"],
  "properties": {
    "schemaVersion": { "const": 2 },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "typeId", "properties"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "typeId": { "type": "string", "minLength": 1 },
          "properties": { "type": "object" },
          "visual": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "rotation": { "enum": [0, 90, 180, 270] }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    },
    "topology": {
      "type": "object",
      "description": "Fonte canônica v2 de conectividade -- substitui o antigo array `wires[]` (schemaVersion 1). Nós topológicos (junções de grau N) não são mais componentes de simulação -- ver .spec/lasecsimul.spec, ADR sobre remoção de connectors.junction do Core.",
      "required": ["revision", "nodes", "conductors"],
      "properties": {
        "revision": { "type": "integer", "minimum": 0 },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "position"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "position": {
                "type": "object",
                "required": ["x", "y"],
                "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
              }
            },
            "additionalProperties": false
          }
        },
        "conductors": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "from", "to"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "from": { "$ref": "#/$defs/topologyEndpoint" },
              "to": { "$ref": "#/$defs/topologyEndpoint" },
              "vertices": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["x", "y"],
                  "properties": { "x": { "type": "number" }, "y": { "type": "number" } }
                }
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "visual": {
      "type": "object",
      "required": ["viewport"],
      "properties": {
        "viewport": {
          "type": "object",
          "required": ["x", "y", "zoom"],
          "properties": {
            "x": { "type": "number" },
            "y": { "type": "number" },
            "zoom": { "type": "number" }
          }
        }
      },
      "additionalProperties": true
    },
    "simulationSettings": { "type": "object" },
    "mcuFirmware": { "type": "array" }
  },
  "additionalProperties": true,
  "$defs": {
    "topologyEndpoint": {
      "type": "object",
      "oneOf": [
        {
          "required": ["kind", "componentId", "pinId"],
          "properties": {
            "kind": { "const": "port" },
            "componentId": { "type": "string", "minLength": 1 },
            "pinId": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        {
          "required": ["kind", "nodeId"],
          "properties": {
            "kind": { "const": "node" },
            "nodeId": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
